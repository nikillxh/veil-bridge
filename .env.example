# ---------------------------------------------------------------------------
# QIE ZK Privacy Bridge - environment template. Copy to .env and fill in.
# ---------------------------------------------------------------------------

# --- RPC endpoints ---
# Source EVM chain (the demo uses Sepolia).
SOURCE_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# QIE testnet (chain id 1983). Pick any working RPC from the docs.
QIE_RPC_URL=https://rpc1testnet.qie.digital/

# --- Keys (NEVER commit real keys) ---
# Deploys contracts + the Poseidon hasher on the source chain.
DEPLOYER_PRIVATE_KEY=0x...
# Submits deposits on the source chain.
DEPOSITOR_PRIVATE_KEY=0x...
# Relayer account on QIE (pays gas to submit proven roots).
RELAYER_PRIVATE_KEY=0x...
# Fresh wallet that claims on QIE (must be unlinked from the depositor!).
CLAIMER_PRIVATE_KEY=0x...

# --- Deployed addresses (filled in after deployment) ---
HASHER_ADDRESS=
VAULT_ADDRESS=
UPDATER_ADDRESS=
POOL_ADDRESS=
WRAPPED_ADDRESS=

# --- Bridge parameters ---
DENOMINATION=1000000000000000000   # 1e18, fixed deposit size
LEVELS=20                          # Merkle tree depth
ROOT_SLOT=3                        # storage slot of ShieldedVault.latestRoot
CONFIRMATIONS=8
POLL_INTERVAL_SECS=15

# --- SP1 (only needed for real trustless proving: relayer --features sp1) ---
SP1_VKEY=
SP1_ELF_PATH=
# SP1_VERIFIER=   # real SP1 gateway on QIE; omit to use SP1MockVerifier
