# Frontend env (set these in Vercel Project Settings -> Environment Variables).
# All are exposed to the browser, so use public RPCs and addresses only.

# RPC endpoints
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_QIE_RPC_URL=https://rpc1testnet.qie.digital/

# Deployed contract addresses (from forge script output)
NEXT_PUBLIC_VAULT_ADDRESS=0x...
NEXT_PUBLIC_TOKEN_ADDRESS=0x...
NEXT_PUBLIC_UPDATER_ADDRESS=0x...
NEXT_PUBLIC_POOL_ADDRESS=0x...
NEXT_PUBLIC_WRAPPED_ADDRESS=0x...

# Merkle tree depth (must match the deployed vault) and the vault deploy block
# (speeds up event scanning on claim).
NEXT_PUBLIC_MERKLE_LEVELS=20
NEXT_PUBLIC_VAULT_DEPLOY_BLOCK=0
